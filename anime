<!DOCTYPE html>
<html lang="ms">
<head>
<meta charset="UTF-8" />
<meta https-equiv="X-UA-Compatible" content="IE=edge" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>IMAN</title>

</head>

<style>
body {
margin: 0;
}

.container {
position: relative;
text-align: center;
background: linear-gradient{
60deg,
rgba(84, 58, 183, 1) 0%,
rgba(0, 172, 193, 1) 100%
);
color: white;
}

.waves {
position: relative;
width:100%;
height: 20vh;
margin-bottom: -7px;
min-height: 100px;
max-height: 350px;
}

.waves-effect > use {
animation: movement 25s cubic-bezier(0.55, 0.5, 0.45, 0.5) infinite;
}

.waves-effect > use:nth-child(1) {
animation-delay: -2s;
animation-duration: 7s;
}

.waves-effect > use:nth-child(2) {
animation-delay: -3s;
animation-duration: 10s;
}

.waves-effect > use:nth-child(3) {
animation-delay: -4s;
animation-duration: 13s;
}

.waves-effect > use:nth-child(4) {
animation-delay: -5s;
animation-duration: 20s;

@keyframe movement {
0% {
transform: translate3d(-90px, 0, 0);
}
100% {
transform: translate3d(85px, 0, 0);
}
}

@media (max-width: 768px) {
.wavees {
height: 3em;
min-height: 60px;
}
}
}
